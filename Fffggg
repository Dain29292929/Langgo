local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")

local LocalPlayer = Players.LocalPlayer
local SharedModules = ReplicatedStorage:WaitForChild("SharedModules", 120)
local ClientModules = ReplicatedStorage:WaitForChild("ClientModules", 120)
local Networking = require(SharedModules:WaitForChild("Networking"))
local PlayerStateClient = require(ClientModules:WaitForChild("PlayerStateClient"))

local cats = {
	"Pets", "Sprinklers", "WateringCans", "Mushrooms", "Gnomes", "Raccoons",
	"Crates", "SeedPacks", "Trowels", "Props", "Seeds", "HarvestedFruits", "EmptyPots",
}

repeat task.wait() until LocalPlayer:HasTag("DataLoaded")
task.wait(1)

local replica = PlayerStateClient:GetLocalReplica() or PlayerStateClient:WaitForLocalReplica(30)
local inv = replica and replica.Data and replica.Data.Inventory
if not inv then
	warn("인벤토리 데이터를 불러올 수 없습니다.")
	return
end

-- 인벤토리 데이터 정리
local categoryItems = {}
for _, cat in cats do
	local bucket = inv[cat]
	if typeof(bucket) \~= "table" then continue end
	
	categoryItems[cat] = {}
	
	if cat == "Pets" or cat == "HarvestedFruits" then
		for key, entry in bucket do
			if typeof(entry) == "table" and entry.Id then
				if cat == "Pets" and entry.Equipped then continue end
				table.insert(categoryItems[cat], {key = key, count = 1})
			end
		end
	else
		for key, count in bucket do
			if typeof(count) == "number" and count > 0 then
				if string.find(string.lower(tostring(key)), "watering can", 1, true) then continue end
				table.insert(categoryItems[cat], {key = key, count = count})
			end
		end
	end
end

