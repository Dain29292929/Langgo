-- 카테고리 버튼 생성
local function createCategoryButton(catName, itemCount)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, -10, 0, 28)
	btn.BackgroundColor3 = Color3.fromRGB(55, 55, 70)
	btn.TextColor3 = Color3.white
	btn.Text = string.format("%s (%d)", catName, itemCount)
	btn.TextSize = 14
	btn.Font = Enum.Font.Gotham
	btn.Parent = catScroll
	
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 6)
	corner.Parent = btn
	
	btn.MouseButton1Click:Connect(function()
		-- 이전 아이템 목록 초기화
		for _, child in itemScroll:GetChildren() do
			if child:IsA("TextButton") then child:Destroy() end
		end
		
		selectedCat = catName
		selectedKey = nil
		selectedMaxCount = 0
		selectedLabel.Text = "선택된 아이템: 없음"
		countBox.Text = "1"
		
		-- 아이템 목록 생성
		local items = categoryItems[catName] or {}
		for _, item in items do
			local itemBtn = Instance.new("TextButton")
			itemBtn.Size = UDim2.new(1, -8, 0, 26)
			itemBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 75)
			itemBtn.TextColor3 = Color3.fromRGB(220, 220, 220)
			itemBtn.Text = string.format("%s  (보유: %d)", item.key, item.count)
			itemBtn.TextSize = 13
			itemBtn.Font = Enum.Font.Gotham
			itemBtn.Parent = itemScroll
			
			local icorner = Instance.new("UICorner")
			icorner.CornerRadius = UDim.new(0, 5)
			icorner.Parent = itemBtn
			
			itemBtn.MouseButton1Click:Connect(function()
				selectedKey = item.key
				selectedMaxCount = item.count
				selectedLabel.Text = string.format("선택된 아이템: %s (최대 %d개)", item.key, item.count)
				countBox.Text = tostring(math.min(tonumber(countBox.Text) or 1, item.count))
			end)
		end
		
		-- 스크롤 크기 조정
		itemScroll.CanvasSize = UDim2.new(0, 0, 0, #items * 29)
	end)
	
	return btn
end

-- 카테고리 목록 채우기 (아이템 있는 것만)
local totalCats = 0
for _, cat in cats do
	local items = categoryItems[cat]
	if items and #items > 0 then
		createCategoryButton(cat, #items)
		totalCats += 1
	end
end

catScroll.CanvasSize = UDim2.new(0, 0, 0, totalCats * 32)

-- 보내기 버튼 기능
sendButton.MouseButton1Click:Connect(function()
	if not selectedCat or not selectedKey then
		statusLabel.Text = "⚠️ 카테고리와 아이템을 먼저 선택하세요!"
		statusLabel.TextColor3 = Color3.fromRGB(255, 150, 150)
		task.delay(2, function()
			if statusLabel then statusLabel.Text = "" end
		end)
		return
	end
	
	local count = tonumber(countBox.Text) or 1
	if count < 1 then count = 1 end
	if count > selectedMaxCount then count = selectedMaxCount end
	
	-- 배치 생성
	local batch = {
		{Category = selectedCat, ItemKey = selectedKey, Count = count}
	}
	
	local targetPlayer = targetBox.Text
	if targetPlayer == "" then
		statusLabel.Text = "⚠️ 받을 사람 닉네임을 입력하세요!"
		statusLabel.TextColor3 = Color3.fromRGB(255, 150, 150)
		return
	end
	
	local uid = Networking.Mailbox.LookupPlayer:Fire(targetPlayer)
	if typeof(uid) \~= "number" or uid <= 0 then
		statusLabel.Text = "❌ 대상 플레이어를 찾을 수 없습니다."
		statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
		return
	end
	
	local success = pcall(function()
		Networking.Mailbox.SendBatch:Fire(uid, batch, "GUI 전송")
	end)
	
	if success then
		statusLabel.Text = string.format("✅ %s x%d 전송 완료!", selectedKey, count)
		statusLabel.TextColor3 = Color3.fromRGB(100, 255, 150)
		-- 선택 초기화
		selectedKey = nil
		selectedLabel.Text = "선택된 아이템: 없음"
	else
		statusLabel.Text = "❌ 전송 실패 (오류 발생)"
		statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
	end
	
	task.delay(3, function()
		if statusLabel then statusLabel.Text = "" end
	end)
end)

