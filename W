-- ============================================================
-- Coin Walker v4 (개선판)
-- - 추적 중 코인 사라짐 즉시 감지 → 새 타겟으로 전환
-- - MoveToFinished 자체 타임아웃 추가 (끼임 방지)
-- - 점프 타이밍 개선 (MoveTo 전에 미리 Jump)
-- - 루프 지연 최소화
-- ============================================================

local PathfindingService = game:GetService("PathfindingService")
local Players = game:GetService("Players")

local plr = Players.LocalPlayer
local char = plr.Character or plr.CharacterAdded:Wait()
local hrp = char:WaitForChild("HumanoidRootPart")
local humanoid = char:WaitForChild("Humanoid")

plr.CharacterAdded:Connect(function(newChar)
    char = newChar
    hrp = newChar:WaitForChild("HumanoidRootPart")
    humanoid = newChar:WaitForChild("Humanoid")
end)

local function isAlive()
    return humanoid and humanoid.Health > 0 and hrp and hrp.Parent
end

local function getClosestCoin()
    local coinsFolder = workspace:FindFirstChild("Game")
    if coinsFolder then coinsFolder = coinsFolder:FindFirstChild("Coins") end
    if not coinsFolder then return nil end

    local closestCoin = nil
    local shortestDistance = math.huge
    local hrpPos = hrp.Position

    for _, part in pairs(coinsFolder:GetChildren()) do
        if part:IsA("BasePart") then
            local distance = (part.Position - hrpPos).Magnitude
            if distance < shortestDistance then
                shortestDistance = distance
                closestCoin = part
            end
        end
    end
    return closestCoin
end

-- waypoint 하나로 이동, 타임아웃 + 도착 감지를 직접 처리 (MoveToFinished 끼임 방지)
local function moveToWaypoint(position, waypointTimeout)
    if not isAlive() then return false end

    humanoid:MoveTo(position)

    local connection
    local finished = false
    local startTime = tick()

    connection = humanoid.MoveToFinished:Connect(function()
        finished = true
    end)

    while not finished do
        if not isAlive() then
            connection:Disconnect()
            return false
        end
        if tick() - startTime > waypointTimeout then
            connection:Disconnect()
            return false -- 끼임/타임아웃으로 판단, 호출부에서 새 경로 재계산
        end
        task.wait(0.05)
    end

    connection:Disconnect()
    return true
end

local lastDeathTime = 0
local DEATH_COOLDOWN = 6
local MOVE_TIMEOUT = 5       -- 코인 하나당 전체 이동 제한
local WAYPOINT_TIMEOUT = 1.5 -- 웨이포인트 하나당 제한 (끼임 감지용)

while true do
    pcall(function()
        if not isAlive() then
            task.wait(0.2)
            return
        end

        local canDo = true

        pcall(function()
            local spec = plr:FindFirstChild("PlayerGui")
                and plr.PlayerGui:FindFirstChild("MainUI")
                and plr.PlayerGui.MainUI:FindFirstChild("MobileNav")
                and plr.PlayerGui.MainUI.MobileNav:FindFirstChild("Buttons")
                and plr.PlayerGui.MainUI.MobileNav.Buttons:FindFirstChild("Spectate")

            if spec and spec.ImageTransparency == 0 then
                canDo = false
            end
        end)

        if canDo and isAlive() then
            local closestCoin = getClosestCoin()
            if closestCoin then
                pcall(function()
                    local path = PathfindingService:CreatePath({
                        AgentRadius = 2,
                        AgentHeight = 5,
                        AgentCanJump = true
                    })

                    local targetPos = closestCoin.Position
                    path:ComputeAsync(hrp.Position, targetPos + Vector3.new(3, 0, 3))

                    if path.Status == Enum.PathStatus.Success then
                        local startTime = tick()
                        local waypoints = path:GetWaypoints()

                        for i, waypoint in ipairs(waypoints) do
                            -- 전체 타임아웃
                            if tick() - startTime > MOVE_TIMEOUT then
                                print("[CoinWalker] 5초 초과 → 다른 코인으로 전환")
                                break
                            end

                            -- 코인이 사라졌는지 매 웨이포인트마다 체크
                            if not closestCoin.Parent then
                                print("[CoinWalker] 코인이 사라짐 → 새 타겟 탐색")
                                break
                            end

                            if not isAlive() then break end

                            -- 점프는 이동 시작 직전에 걸어야 타이밍이 맞음
                            if waypoint.Action == Enum.PathWaypointAction.Jump then
                                humanoid.Jump = true
                            end

                            local reached = moveToWaypoint(waypoint.Position, WAYPOINT_TIMEOUT)
                            if not reached then
                                -- 끼였거나 타임아웃 → 이 코인 포기하고 다음 루프에서 재탐색
                                break
                            end
                        end

                        -- 수집 (코인이 아직 있고 타임아웃 안 됐을 때만)
                        if tick() - startTime <= MOVE_TIMEOUT and closestCoin.Parent then
                            task.wait(0.08)
                            firetouchinterest(hrp, closestCoin, 0)
                            task.wait(0.06)
                            firetouchinterest(hrp, closestCoin, 1)
                        end
                    end
                end)
            end
        end

        if tick() - lastDeathTime > DEATH_COOLDOWN then
            pcall(function()
                local coinText = plr:FindFirstChild("PlayerGui")
                if coinText then coinText = coinText:FindFirstChild("MainUI") end
                if coinText then coinText = coinText:FindFirstChild("Round") end
                if coinText then coinText = coinText:FindFirstChild("Coin") end
                if coinText then coinText = coinText:FindFirstChild("Coin") end
                if coinText then coinText = coinText:FindFirstChild("CoinCount") end

                if coinText and coinText.Text and (coinText.Text == "100 / 100" or coinText.Text == "50 / 50") then
                    if isAlive() then
                        humanoid.Health = 0
                        lastDeathTime = tick()
                        print("[CoinWalker] 코인 풀 → 사망 처리")
                    end
                end
            end)
        end
    end)

    task.wait(0.03)
end
